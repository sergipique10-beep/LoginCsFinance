# Desarrollo local (HTTPS con mkcert)
BASE_URL=https://localhost:8001
FRONTEND_URL=https://localhost:4200

# Orígenes de retorno permitidos tras la auth de Steam (separar por coma).
# Incluye la URL web y el scheme nativo de Android.
ALLOWED_REDIRECT_ORIGINS=https://localhost:4200,myapp://auth/callback

# Producción (ejemplo)
# BASE_URL=https://api.csfinance.com
# FRONTEND_URL=https://csfinance.com
# ALLOWED_REDIRECT_ORIGINS=https://csfinance.com,myapp://auth/callback

# Requerido: secreto fuerte para firmar los JWT
# Generar con: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=change-this-secret

# Opcional: Steam Web API key para enriquecer el perfil en el futuro
STEAM_API_KEY=
