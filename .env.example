# Desarrollo local (HTTPS con mkcert)
BASE_URL=https://localhost:8000
FRONTEND_URL=https://localhost:4200

# Orígenes de retorno permitidos tras la auth de Steam (separar por coma).
# Incluye la URL web y el scheme nativo de Android.
ALLOWED_REDIRECT_ORIGINS=https://localhost:4200,myapp://auth/callback

# Producción (ejemplo)
# BASE_URL=https://api.csfinance.com
# FRONTEND_URL=https://csfinance.com
# ALLOWED_REDIRECT_ORIGINS=https://csfinance.com,myapp://auth/callback

# Requerido: secreto fuerte para firmar los JWT
# Generar con: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=change-this-secret

# Opcional: Steam Web API key para enriquecer el perfil en el futuro
STEAM_API_KEY=

# Activa /auth/dev-token para pruebas con Postman sin flujo Steam OpenID.
# NUNCA poner a true en producción.
DEBUG=false

# ── Supabase (histórico del índice de precio CS2) ──────────────────────────────
# Proyecto Supabase dedicado "cs-finance" (Postgres). El backend usa la
# service_role key, que bypassa RLS — NO usar la anon/publishable key.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service-role-key>

# Token compartido que protege POST /internal/cap-tick (cron de GitHub Actions).
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
CAP_TICK_TOKEN=change-this-cap-tick-token

# ── Push notifications (Firebase Admin SDK) ─────────────────────────────────
# Token compartido que protege POST /internal/news-tick (cron de GitHub Actions).
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
NEWS_TICK_TOKEN=

# Token compartido que protege POST /internal/broadcast (anuncio manual desde
# el workflow_dispatch "broadcast" de GitHub Actions). Token propio, distinto
# del de news-tick. Generar igual que el anterior.
BROADCAST_TOKEN=

# JSON completo de la service account de Firebase (Firebase Admin SDK).
# Obtener desde Firebase Console → Project Settings → Service accounts → Generate new private key.
# Pegar el contenido del JSON como un solo string.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Gemini (Google AI Studio) — chat del asistente Sharky (POST /rag/chat).
# Obtener una API key gratuita en https://aistudio.google.com/apikey
# Vive SOLO en el backend; el frontend nunca la ve.
GEMINI_API_KEY=
# Modelo por defecto: gemini-flash-latest (con free tier para cuentas nuevas).
# Ojo: muchos modelos con nombre de versión fija (gemini-2.0-flash, 2.5-flash…)
# devuelven 404 "no longer available to new users" o 429 con quota 0 en cuentas
# nuevas. gemini-flash-latest apunta siempre al Flash vigente con free tier.
GEMINI_MODEL=gemini-flash-latest

# RAG de noticias CS2
GEMINI_EMBED_MODEL=gemini-embedding-001
RAG_INGEST_TOKEN=
RAG_FEEDS=https://blog.counter-strike.net/feed/
# Similitud mínima (cosine, 0..1) para citar un chunk como fuente en /rag/ask.
RAG_MIN_SIMILARITY=0.5

# Captura de precios históricos por-skin
PRICE_TICK_TOKEN=
PRICE_LOOKUP_CAP=400
